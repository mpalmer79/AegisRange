# ============================================================
# AegisRange Environment Variables
# ============================================================
# Copy to .env and fill in values for local development.
# On Railway, set these in the service's Variables tab.

# --- Backend ---
APP_ENV=development                    # development | production
LOG_LEVEL=INFO                         # DEBUG | INFO | WARNING | ERROR
LOG_FORMAT=json                        # json | text
CORS_ORIGINS=http://localhost:3000     # comma-separated allowed origins
JWT_SECRET=                            # REQUIRED in production (generate: python -c "import secrets; print(secrets.token_urlsafe(64))")
JWT_SECRET_PREVIOUS=                   # Previous JWT secret for seamless key rotation (set during rotation window)
TOKEN_EXPIRY_HOURS=24                  # JWT token lifetime
DB_PATH=/data/aegisrange.db            # SQLite path (use /data/ for Railway volume)
LOCKOUT_THRESHOLD=5                    # Failed login attempts before lockout (NIST 800-53 AC-7)
LOCKOUT_DURATION_MINUTES=15            # Minutes an account stays locked after threshold
PASSWORD_MIN_LENGTH=10                 # Minimum password length
PASSWORD_REQUIRE_UPPERCASE=true        # Require uppercase letter in password
PASSWORD_REQUIRE_LOWERCASE=true        # Require lowercase letter in password
PASSWORD_REQUIRE_DIGIT=true            # Require digit in password
PASSWORD_REQUIRE_SPECIAL=true          # Require special character in password

# --- Frontend ---
NEXT_PUBLIC_API_URL=                        # Override API base URL (optional; leave blank for proxy)
BACKEND_URL=http://localhost:8000           # Backend URL for Next.js rewrite proxy (server-side, build-time on Railway)
NEXT_PUBLIC_DEMO_MODE=                      # Set to "true" to enable demo mode (static red_team identity, no login required)
